# epiweather-api 환경변수 예시
# 실제 값을 채운 뒤 .env로 복사해서 사용 (.env는 .gitignore로 커밋 제외됨).

# ── 필수: 쓰기(POST) 엔드포인트 인증 ──────────────────────────
# 설정 안 하면 모든 POST 엔드포인트가 503으로 막힘(fail-closed).
# openssl rand -hex 32 등으로 임의 문자열 생성해서 사용.
EPIWEATHER_API_KEY=

# 선택: 고객사/파트너별로 키를 따로 발급하고 싶을 때 "라벨:키" 쌍을 쉼표로
# 나열. EPIWEATHER_API_KEY(위)는 label="default"로 계속 같이 동작함.
# 예: EPIWEATHER_API_KEYS=airline_partner_a:xxxx,internal_dashboard:yyyy
EPIWEATHER_API_KEYS=

# ── CORS: 배포된 프론트엔드 도메인 (쉼표로 구분) ──────────────
ALLOWED_ORIGINS=

# ── 실데이터 소스 ─────────────────────────────────────────────
KDCA_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── AI 갭필링 ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# ── 행동 신호 (Phase2) ────────────────────────────────────────
HIRA_API_KEY=
SEOUL_OPEN_DATA_KEY=

# ── 이동성/동물신호 (선택, 없어도 무료 티어로 동작) ───────────
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
WAHIS_API_KEY=

# ── 스케줄러 ──────────────────────────────────────────────────
# 로컬에서 별도 작업 스케줄러(cron 등)를 이미 쓰고 있어 API 프로세스 내장
# 스케줄러와 중복 수집하면 안 될 때 off로 설정.
EPIWEATHER_SCHEDULER=on
