# epiweather-api 환경변수 예시
# 실제 값을 채운 뒤 .env로 복사해서 사용 (.env는 .gitignore로 커밋 제외됨).

# ── 필수: 쓰기(POST) 엔드포인트 인증 ──────────────────────────
# 설정 안 하면 모든 POST 엔드포인트가 503으로 막힘(fail-closed).
# openssl rand -hex 32 등으로 임의 문자열 생성해서 사용.
EPIWEATHER_API_KEY=

# 선택: 고객사/파트너별로 키를 따로 발급하고 싶을 때 "라벨:키" 쌍을 쉼표로
# 나열. EPIWEATHER_API_KEY(위)는 label="default"로 계속 같이 동작함.
# 예: EPIWEATHER_API_KEYS=airline_partner_a:xxxx,internal_dashboard:yyyy
EPIWEATHER_API_KEYS=

# ── CORS: 배포된 프론트엔드 도메인 (쉼표로 구분) ──────────────
ALLOWED_ORIGINS=

# ── 실데이터 소스 ─────────────────────────────────────────────
KDCA_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── AI 갭필링 ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# ── 행동 신호 (Phase2) ────────────────────────────────────────
HIRA_API_KEY=
SEOUL_OPEN_DATA_KEY=

# ── 이동성/동물신호 (선택, 없어도 무료 티어로 동작) ───────────
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
WAHIS_API_KEY=

# ── 토지이용/벌목 선행지표 (선택) ─────────────────────────────
# NASA FIRMS 활성 화재 탐지 → 벌목·화전(land-clearing) 프록시. 스필오버
# 1순위 동인인 삼림파괴의 선행 신호. 없으면 /api/land-signals가 조용히
# data_available=False로 표시(다른 조회는 정상). 무료 발급:
# https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# Global Forest Watch 통합 산림손실 알림(GLAD/RADD 위성) → 화재 프록시가 아닌
# 직접 산림손실 측정. 없으면 /api/deforestation-signals가 조용히
# data_available=False. 무료 발급: https://data-api.globalforestwatch.org/
GFW_API_KEY=

# ── 실시간 알림 (선택) ────────────────────────────────────────
# critical·high 등급 신규 경보를 Telegram으로 즉시 발송. 둘 다 없으면
# 조용히 꺼진 채로 동작(대시보드 조회는 그대로 됨).
# 발급: @BotFather에게 /newbot 메시지 → 토큰 발급(무료, 30초).
# TELEGRAM_CHAT_ID: 알림 받을 개인 채팅 또는 채널 ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 스케줄러 ──────────────────────────────────────────────────
# 로컬에서 별도 작업 스케줄러(cron 등)를 이미 쓰고 있어 API 프로세스 내장
# 스케줄러와 중복 수집하면 안 될 때 off로 설정.
EPIWEATHER_SCHEDULER=on
